@page
@model ProjectTimeTracker.Web.Pages.Sessione.SelezionaUtenteModel
@{
    ViewData["Title"] = "Seleziona utente";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-stat">
            <div class="section-title">Utente di lavoro</div>
            <p class="soft-muted">
                Seleziona l’utente corrente da usare nella sessione. Questo utente verrà usato per registrare i tempi lavorati e le operazioni applicative.
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
            {
                <div class="alert alert-danger">
                    <div class="fw-bold mb-1">Errore nel caricamento utenti</div>
                    <div>@Model.LoadErrorMessage</div>
                </div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.UserId" class="form-label">Utente</label>
                    <select asp-for="Input.UserId" asp-items="Model.Utenti" class="form-select" disabled="@(Model.LoadErrorMessage != null)">
                        <option value="">-- Seleziona utente --</option>
                    </select>
                    <span asp-validation-for="Input.UserId" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@(Model.LoadErrorMessage != null)">Conferma</button>
                    <a asp-page="/Index" class="btn btn-outline-light">Annulla</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}